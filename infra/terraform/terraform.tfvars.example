# Terraform variables for ADV RAG deployment
# Copy this file to terraform.tfvars and fill in your values.

project_name = "adv-rag"
environment  = "prod"
aws_region   = "us-east-1"

# Networking (must exist beforehand)
vpc_id             = "vpc-xxxxxxxxxxxxxxxxx"
public_subnet_ids  = ["subnet-xxxxxxxxxxxxxxxxx", "subnet-yyyyyyyyyyyyyyyyy"]
private_subnet_ids = ["subnet-zzzzzzzzzzzzzzzzz", "subnet-wwwwwwwwwwwwwwwww"]

# Container image (push to ECR first)
container_image = "123456789012.dkr.ecr.us-east-1.amazonaws.com/adv-rag-prod-app:latest"

# Secrets Manager ARNs (create these first)
openai_api_key_secret_arn    = "arn:aws:secretsmanager:us-east-1:123456789012:secret:openai-api-key-XXXXXX"
jwt_secret_secret_arn        = "arn:aws:secretsmanager:us-east-1:123456789012:secret:jwt-secret-XXXXXX"
database_url_secret_arn      = "arn:aws:secretsmanager:us-east-1:123456789012:secret:database-url-XXXXXX"
upstash_redis_url_secret_arn = "arn:aws:secretsmanager:us-east-1:123456789012:secret:upstash-redis-url-XXXXXX"
upstash_redis_token_secret_arn = "arn:aws:secretsmanager:us-east-1:123456789012:secret:upstash-redis-token-XXXXXX"
tavily_api_key_secret_arn    = "arn:aws:secretsmanager:us-east-1:123456789012:secret:tavily-api-key-XXXXXX"

# Optional overrides
# ecs_task_cpu    = 2048
# ecs_task_memory = 16384
# desired_count   = 1
# enable_autoscaling = false
